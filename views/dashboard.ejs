<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Bot Operations Dashboard</title>

  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script src="https://unpkg.com/@phosphor-icons/web"></script>
  <script src="/socket.io/socket.io.js"></script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Sora:wght@500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/dashboard.css">
</head>
<body>
  <div class="dashboard-app">
    <aside class="sidebar" id="sidebar">
      <div class="sidebar-brand">
        <div class="brand-mark">
          <i class="ph-fill ph-rocket-launch"></i>
        </div>
        <div>
          <strong>Bot Console</strong>
          <span>Operations center</span>
        </div>
      </div>

      <nav class="sidebar-nav">
        <button class="sidebar-link active" data-panel-target="overview">
          <i class="ph-fill ph-squares-four"></i>
          <span>Dashboard</span>
        </button>
        <button class="sidebar-link" data-panel-target="users">
          <i class="ph-fill ph-users-three"></i>
          <span>Users</span>
        </button>
        <button class="sidebar-link" data-panel-target="donations">
          <i class="ph-fill ph-hand-heart"></i>
          <span>Donations</span>
        </button>
      </nav>

      <div class="sidebar-card">
        <div class="sidebar-card-head">
          <span class="status-dot" id="socketDot"></span>
          <strong id="socketStatusText">Live sync connected</strong>
        </div>
        <p>Realtime updates for users, downloads, moderation, and donations.</p>
      </div>

      <div class="sidebar-mini-grid">
        <article class="mini-card">
          <span>Uptime</span>
          <strong id="uptimeValue">0m</strong>
        </article>
        <article class="mini-card">
          <span>Refresh</span>
          <strong id="generatedAt">just now</strong>
        </article>
        <article class="mini-card">
          <span>Blocked</span>
          <strong id="moderationState">0</strong>
        </article>
        <article class="mini-card">
          <span>Health</span>
          <strong id="healthState">Healthy</strong>
        </article>
      </div>
    </aside>

    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    <main class="main-shell">
      <header class="topbar">
        <div class="topbar-left">
          <button class="sidebar-toggle" id="sidebarToggle" aria-label="Open menu">
            <i class="ph ph-list"></i>
          </button>
          <div>
            <div class="eyebrow">
              <span class="eyebrow-dot"></span>
              Live operations
            </div>
            <h1 id="panelTitle">Dashboard</h1>
            <p id="panelSubtitle">Overview of users, downloads, moderation, and donations.</p>
          </div>
        </div>

        <div class="topbar-meta">
          <div class="meta-chip">
            <span>Last sync</span>
            <strong id="topGeneratedAt">just now</strong>
          </div>
          <div class="meta-chip highlight">
            <span>Donations</span>
            <strong id="topDonationStat">0</strong>
          </div>
        </div>
      </header>

      <section class="panel-view active" data-panel="overview">
        <section class="hero-panel">
          <div class="hero-copy">
            <div class="eyebrow">
              <span class="eyebrow-dot"></span>
              Bot overview
            </div>
            <h2>All bot stats in one place</h2>
            <p>
              Monitor downloads, platform usage, user growth, moderation state, and donation performance from a cleaner control surface.
            </p>
          </div>

          <div class="hero-summary" id="heroSummary"></div>
        </section>

        <section class="stats-grid" id="statsGrid"></section>

        <section class="layout-grid overview-charts">
          <article class="panel">
            <div class="section-head">
              <div>
                <h2>Download flow</h2>
                <p>Successful deliveries and failures over the last 7 days.</p>
              </div>
            </div>
            <div class="chart-wrap">
              <canvas id="downloadsChart"></canvas>
            </div>
          </article>

          <article class="panel">
            <div class="section-head">
              <div>
                <h2>User growth</h2>
                <p>New users joining over the last 7 days.</p>
              </div>
            </div>
            <div class="chart-wrap">
              <canvas id="signupsChart"></canvas>
            </div>
          </article>

          <article class="panel">
            <div class="section-head">
              <div>
                <h2>Donation flow</h2>
                <p>Donation creation and successful payments over the last 7 days.</p>
              </div>
            </div>
            <div class="chart-wrap">
              <canvas id="donationsChart"></canvas>
            </div>
          </article>
        </section>

        <section class="layout-grid">
          <article class="panel">
            <div class="section-head">
              <div>
                <h2>Usage breakdowns</h2>
                <p>Quick view of platforms, media types, language split, and donation states.</p>
              </div>
            </div>
            <div class="breakdowns-grid">
              <section class="mini-section">
                <h3>Platforms</h3>
                <div class="stack-list" id="platformBreakdown"></div>
              </section>
              <section class="mini-section">
                <h3>Media types</h3>
                <div class="stack-list" id="mediaBreakdown"></div>
              </section>
              <section class="mini-section">
                <h3>Languages</h3>
                <div class="stack-list" id="languageBreakdown"></div>
              </section>
              <section class="mini-section">
                <h3>Donation status</h3>
                <div class="stack-list" id="donationStatusBreakdown"></div>
              </section>
              <section class="mini-section">
                <h3>Donation currency</h3>
                <div class="stack-list" id="donationCurrencyBreakdown"></div>
              </section>
              <section class="mini-section">
                <h3>Active users</h3>
                <div class="stack-list" id="activeUsersSnapshot"></div>
              </section>
            </div>
          </article>

          <article class="panel">
            <div class="section-head">
              <div>
                <h2>Recent downloads</h2>
                <p>Latest successful and failed requests across all platforms.</p>
              </div>
            </div>
            <div class="feed-list" id="recentDownloadsList"></div>
          </article>
        </section>

        <section class="layout-grid">
          <article class="panel">
            <div class="section-head">
              <div>
                <h2>Recent donations</h2>
                <p>Latest KHQR donations and payment states.</p>
              </div>
            </div>
            <div class="feed-list" id="recentDonationsList"></div>
          </article>

          <article class="panel">
            <div class="section-head">
              <div>
                <h2>Top and active users</h2>
                <p>Most active members and recently seen users.</p>
              </div>
            </div>
            <div class="split-feed">
              <section>
                <div class="subsection-head">
                  <h3>Top users</h3>
                </div>
                <div class="feed-list" id="topUsersList"></div>
              </section>
              <section>
                <div class="subsection-head">
                  <h3>Active now</h3>
                </div>
                <div class="feed-list" id="activeUsersList"></div>
              </section>
            </div>
          </article>
        </section>
      </section>

      <section class="panel-view" data-panel="users">
        <section class="panel">
          <div class="section-head">
            <div>
              <h2>User management</h2>
              <p>Search, sort, filter, and moderate every stored user.</p>
            </div>
            <span class="section-badge" id="usersResultsMeta">0 users</span>
          </div>

          <div class="toolbar-grid">
            <label class="toolbar-field search-field">
              <span>Search</span>
              <input id="usersSearch" type="search" placeholder="Name, username, Telegram ID, link">
            </label>

            <label class="toolbar-field">
              <span>Sort</span>
              <select id="usersSort">
                <option value="activity_desc">Latest activity</option>
                <option value="downloads_desc">Most downloads</option>
                <option value="requests_desc">Most requests</option>
                <option value="donations_desc">Most donations</option>
                <option value="joined_desc">Newest joined</option>
              </select>
            </label>

            <label class="toolbar-field">
              <span>Status</span>
              <select id="usersStatusFilter">
                <option value="all">All users</option>
                <option value="allowed">Allowed</option>
                <option value="blocked">Blocked</option>
              </select>
            </label>

            <label class="toolbar-field">
              <span>Language</span>
              <select id="usersLanguageFilter">
                <option value="all">All languages</option>
                <option value="en">English</option>
                <option value="km">Khmer</option>
              </select>
            </label>

            <label class="toolbar-field">
              <span>Day filter</span>
              <select id="usersDayFilter">
                <option value="all">All time</option>
                <option value="1">Today</option>
                <option value="7">Last 7 days</option>
                <option value="30">Last 30 days</option>
              </select>
            </label>
          </div>

          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>User</th>
                  <th>Language</th>
                  <th>Requests</th>
                  <th>Downloads</th>
                  <th>Donations</th>
                  <th>Last activity</th>
                  <th>Last link</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody id="usersTableBody"></tbody>
            </table>
          </div>

          <div class="responsive-card-list" id="mobileUsersList"></div>
        </section>
      </section>

      <section class="panel-view" data-panel="donations">
        <section class="panel">
          <div class="section-head">
            <div>
              <h2>Donation history</h2>
              <p>Track pending, paid, expired, and failed donation records for each user.</p>
            </div>
            <span class="section-badge" id="donationsResultsMeta">0 donations</span>
          </div>

          <div class="mini-stats-grid" id="donationStatsGrid"></div>

          <div class="toolbar-grid">
            <label class="toolbar-field search-field">
              <span>Search</span>
              <input id="donationsSearch" type="search" placeholder="Name, username, bill number, md5">
            </label>

            <label class="toolbar-field">
              <span>Sort</span>
              <select id="donationsSort">
                <option value="created_desc">Newest first</option>
                <option value="created_asc">Oldest first</option>
                <option value="amount_desc">Highest amount</option>
                <option value="amount_asc">Lowest amount</option>
                <option value="paid_desc">Latest paid</option>
              </select>
            </label>

            <label class="toolbar-field">
              <span>Status</span>
              <select id="donationsStatusFilter">
                <option value="all">All status</option>
                <option value="pending">Pending</option>
                <option value="success">Success</option>
                <option value="expired">Expired</option>
                <option value="failed">Failed</option>
                <option value="unsupported">Unsupported</option>
                <option value="auth_error">Auth error</option>
              </select>
            </label>

            <label class="toolbar-field">
              <span>Currency</span>
              <select id="donationsCurrencyFilter">
                <option value="all">All currency</option>
                <option value="usd">USD</option>
                <option value="khr">KHR</option>
              </select>
            </label>

            <label class="toolbar-field">
              <span>Day filter</span>
              <select id="donationsDayFilter">
                <option value="all">All time</option>
                <option value="1">Today</option>
                <option value="7">Last 7 days</option>
                <option value="30">Last 30 days</option>
              </select>
            </label>
          </div>

          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>User</th>
                  <th>Amount</th>
                  <th>Status</th>
                  <th>Created</th>
                  <th>Paid</th>
                  <th>Expires</th>
                  <th>Bill / MD5</th>
                  <th>Details</th>
                </tr>
              </thead>
              <tbody id="donationsTableBody"></tbody>
            </table>
          </div>

          <div class="responsive-card-list" id="mobileDonationsList"></div>
        </section>
      </section>

      <footer class="footer-bar">
        <span>Responsive layout for desktop, tablet, and phone.</span>
        <span id="footerMeta">Waiting for live data...</span>
      </footer>
    </main>
  </div>

  <div class="toast" id="toast"></div>

  <script>
    window.__INITIAL_DASHBOARD__ = <%- JSON.stringify({ dashboardData, uptime }).replace(/</g, "\\u003c") %>;
  </script>
  <script src="/dashboard.js"></script>
</body>
</html>
