<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> <title>Bot Command Center</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        /* Custom aesthetics */
        body { background-color: #0f172a; }
        .glass-panel {
            background: rgba(30, 41, 59, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .neon-text { text-shadow: 0 0 15px rgba(56, 189, 248, 0.5); }
        
        /* Mobile Table Fix */
        .scrollbar-hide::-webkit-scrollbar { display: none; }
    </style>
</head>
<body class="text-white font-sans min-h-screen p-4 md:p-8">

    <div class="max-w-7xl mx-auto">
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-blue-400 to-purple-500 neon-text">
                    ADMIN DASHBOARD
                </h1>
                <p class="text-slate-400 text-sm">Real-time Node.js Monitor</p>
            </div>
            <div class="flex items-center gap-2 px-3 py-1 bg-green-900/30 border border-green-500/30 rounded-full">
                <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                <span class="text-green-400 text-xs font-bold tracking-wider">SYSTEM ONLINE</span>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
            
            <div class="glass-panel p-6 rounded-2xl flex flex-col justify-between">
                <div class="text-slate-400 text-xs font-bold uppercase tracking-wider mb-2">Total Downloads</div>
                <div id="stat-downloads" class="text-4xl md:text-5xl font-bold text-blue-400">
                    <%= stats.downloads %>
                </div>
            </div>

            <div class="glass-panel p-6 rounded-2xl flex flex-col justify-between">
                <div class="text-slate-400 text-xs font-bold uppercase tracking-wider mb-2">Active Users</div>
                <div id="stat-users" class="text-4xl md:text-5xl font-bold text-purple-400">
                    <%= stats.total_users %>
                </div>
            </div>

             <div class="glass-panel p-6 rounded-2xl flex flex-col justify-between">
                <div class="text-slate-400 text-xs font-bold uppercase tracking-wider mb-2">Server Status</div>
                <div class="text-xl font-medium text-slate-300">
                    Latency: <span class="text-green-400">~24ms</span>
                </div>
            </div>
        </div>

        <div class="glass-panel rounded-2xl overflow-hidden">
            <div class="px-6 py-4 border-b border-white/10 flex justify-between items-center bg-slate-800/50">
                <h3 class="font-bold text-lg text-slate-200">Live Traffic</h3>
                <span class="text-xs text-slate-500">Auto-updating</span>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left whitespace-nowrap">
                    <thead class="bg-slate-900/50 text-slate-400 text-xs uppercase">
                        <tr>
                            <th class="p-4 font-semibold">User Name</th>
                            <th class="p-4 font-semibold">User ID</th>
                            <th class="p-4 font-semibold text-right">Last Action</th>
                        </tr>
                    </thead>
                    <tbody id="user-table" class="divide-y divide-white/5 text-sm">
                        <% users.forEach(user => { %>
                        <tr class="hover:bg-white/5 transition-colors">
                            <td class="p-4 font-medium text-slate-200 flex items-center gap-3">
                                <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-xs font-bold">
                                    <%= user.name.charAt(0) %>
                                </div>
                                <%= user.name %>
                            </td>
                            <td class="p-4 text-slate-500 font-mono">ID-<%= user.id.toString().slice(-4) %></td>
                            <td class="p-4 text-right text-emerald-400 font-mono">
                                <%= new Date(user.last_seen).toLocaleTimeString() %>
                            </td>
                        </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>

    </div>

    <script>
        const socket = io();

        socket.on('update_stats', (data) => {
            // Animate Numbers
            const downloadEl = document.getElementById('stat-downloads');
            downloadEl.innerText = data.stats.downloads;
            // Simple bounce animation
            downloadEl.classList.add('scale-110', 'transition-transform');
            setTimeout(() => downloadEl.classList.remove('scale-110'), 200);

            document.getElementById('stat-users').innerText = data.stats.total_users;

            // Update Table
            const tableBody = document.getElementById('user-table');
            tableBody.innerHTML = ''; 

            data.userList.forEach(user => {
                const row = `
                    <tr class="hover:bg-white/5 transition-colors">
                        <td class="p-4 font-medium text-slate-200 flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-500 to-purple-600 flex items-center justify-center text-xs font-bold">
                                ${user.name.charAt(0)}
                            </div>
                            ${user.name}
                        </td>
                        <td class="p-4 text-slate-500 font-mono">ID-${user.id.toString().slice(-4)}</td>
                        <td class="p-4 text-right text-emerald-400 font-mono">
                            ${new Date(user.last_seen).toLocaleTimeString()}
                        </td>
                    </tr>
                `;
                tableBody.insertAdjacentHTML('beforeend', row);
            });
        });
    </script>
</body>
</html>