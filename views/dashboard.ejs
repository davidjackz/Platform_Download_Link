<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nexus Command | Bot Analytics</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <script src="/socket.io/socket.io.js"></script>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
        rel="stylesheet">

    <style>
        :root {
            --primary: #3b82f6;
            --accent: #8b5cf6;
            --glass-bg: rgba(15, 23, 42, 0.6);
            --glass-border: rgba(255, 255, 255, 0.05);
        }

        body {
            background-color: #020617;
            /* Very dark slate */
            font-family: 'Plus Jakarta Sans', sans-serif;
            color: #94a3b8;
        }

        /* 🌌 Animated Background Mesh */
        .bg-mesh {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: -1;
            background:
                radial-gradient(circle at 15% 50%, rgba(59, 130, 246, 0.08), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(139, 92, 246, 0.08), transparent 25%);
            pointer-events: none;
        }

        /* 🧊 Glass Effect */
        .glass-panel {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        }

        /* ✨ Interactive Cards */
        .stat-card {
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: rgba(255, 255, 255, 0.1);
            box-shadow: 0 10px 40px -10px rgba(59, 130, 246, 0.2);
        }

        .stat-card::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .stat-card:hover::after {
            opacity: 1;
        }

        /* 🖱️ Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #475569;
        }

        /* 📡 Pulse Animation for Live Status */
        @keyframes radar {
            0% {
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4);
            }

            70% {
                box-shadow: 0 0 0 10px rgba(16, 185, 129, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
            }
        }

        .status-dot {
            animation: radar 2s infinite;
        }
    </style>
</head>

<body class="flex h-screen overflow-hidden">

    <div class="bg-mesh"></div>

    <aside
        class="w-20 lg:w-64 glass-panel border-r-0 border-r border-white/5 flex flex-col transition-all duration-300 z-20">
        <div class="h-20 flex items-center justify-center lg:justify-start lg:px-6 border-b border-white/5">
            <div
                class="w-10 h-10 rounded-xl bg-gradient-to-br from-blue-600 to-indigo-600 flex items-center justify-center shadow-lg shadow-blue-900/20">
                <i class="ph-bold ph-robot text-white text-xl"></i>
            </div>
            <div class="hidden lg:block ml-3">
                <h1 class="text-white font-bold text-lg tracking-tight">Nexus<span class="text-blue-500">Bot</span></h1>
                <p class="text-[10px] font-mono text-slate-500">ADMIN CONSOLE v2.0</p>
            </div>
        </div>

        <nav class="flex-1 py-6 space-y-2 px-3">
            <a href="#"
                class="flex items-center gap-3 px-3 py-3 rounded-lg bg-blue-600/10 text-blue-400 border border-blue-500/10 transition-colors">
                <i class="ph-duotone ph-squares-four text-xl"></i>
                <span class="hidden lg:block font-medium">Dashboard</span>
            </a>
            <a href="#"
                class="flex items-center gap-3 px-3 py-3 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-colors group">
                <i class="ph-duotone ph-users text-xl group-hover:text-blue-400 transition-colors"></i>
                <span class="hidden lg:block font-medium">Users</span>
            </a>
            <a href="#"
                class="flex items-center gap-3 px-3 py-3 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-colors group">
                <i class="ph-duotone ph-chart-line-up text-xl group-hover:text-purple-400 transition-colors"></i>
                <span class="hidden lg:block font-medium">Analytics</span>
            </a>
            <a href="#"
                class="flex items-center gap-3 px-3 py-3 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 transition-colors group">
                <i class="ph-duotone ph-gear text-xl group-hover:text-orange-400 transition-colors"></i>
                <span class="hidden lg:block font-medium">Settings</span>
            </a>
        </nav>

        <div class="p-4 border-t border-white/5 hidden lg:block">
            <div class="glass-panel p-3 rounded-lg flex items-center gap-3">
                <div class="relative">
                    <div class="w-2 h-2 rounded-full bg-emerald-500 status-dot"></div>
                </div>
                <div>
                    <p class="text-xs font-semibold text-white">System Operational</p>
                    <p class="text-[10px] text-slate-500">Ping: 24ms</p>
                </div>
            </div>
        </div>
    </aside>

    <main class="flex-1 flex flex-col relative overflow-hidden">

        <header class="h-20 px-8 flex items-center justify-between border-b border-white/5 glass-panel z-10">
            <div>
                <h2 class="text-white font-semibold text-lg">Mission Control</h2>
                <p class="text-xs text-slate-500">Real-time bot performance metrics</p>
            </div>
            <div class="flex items-center gap-6">
                <div
                    class="hidden md:flex items-center gap-2 px-3 py-1 rounded-full bg-emerald-500/10 border border-emerald-500/20">
                    <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></div>
                    <span class="text-xs font-medium text-emerald-400">Socket Connected</span>
                </div>

                <div class="h-8 w-[1px] bg-white/10"></div>

                <div class="flex items-center gap-3">
                    <div class="text-right hidden sm:block">
                        <p class="text-sm font-medium text-white">Admin</p>
                        <p class="text-[10px] text-slate-500">Super User</p>
                    </div>
                    <div class="w-10 h-10 rounded-full bg-slate-800 p-0.5 border border-white/10">
                        <img src="https://ui-avatars.com/api/?name=Admin&background=0f172a&color=3b82f6"
                            class="rounded-full w-full h-full object-cover" alt="Profile">
                    </div>
                </div>
            </div>
        </header>

        <div class="flex-1 overflow-y-auto p-4 md:p-8 space-y-6">

            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                <div class="stat-card glass-panel rounded-2xl p-5">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-2.5 rounded-lg bg-blue-500/10 text-blue-400">
                            <i class="ph-fill ph-download-simple text-xl"></i>
                        </div>
                        <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-white/5 text-slate-400">+12%</span>
                    </div>
                    <h3 id="stat-downloads" class="text-3xl font-bold text-white mb-1">
                        <%= stats.downloads %>
                    </h3>
                    <p class="text-sm font-medium text-slate-500">Total Downloads</p>
                </div>

                <div class="stat-card glass-panel rounded-2xl p-5">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-2.5 rounded-lg bg-purple-500/10 text-purple-400">
                            <i class="ph-fill ph-users text-xl"></i>
                        </div>
                        <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-white/5 text-slate-400">Total</span>
                    </div>
                    <h3 id="stat-total-users" class="text-3xl font-bold text-white mb-1">
                        <%= stats.total_users %>
                    </h3>
                    <p class="text-sm font-medium text-slate-500">Registered Users</p>
                </div>

                <div class="stat-card glass-panel rounded-2xl p-5 relative overflow-hidden group">
                    <div
                        class="absolute -right-4 -top-4 w-20 h-20 bg-emerald-500/20 blur-2xl rounded-full group-hover:bg-emerald-500/30 transition-colors">
                    </div>
                    <div class="flex justify-between items-start mb-4 relative z-10">
                        <div class="p-2.5 rounded-lg bg-emerald-500/10 text-emerald-400">
                            <i class="ph-fill ph-lightning text-xl"></i>
                        </div>
                        <span
                            class="text-[10px] font-bold px-2 py-0.5 rounded bg-emerald-500/20 text-emerald-400 animate-pulse">LIVE</span>
                    </div>
                    <h3 id="stat-active" class="text-3xl font-bold text-white mb-1 relative z-10">
                        <%= stats.active_now %>
                    </h3>
                    <p class="text-sm font-medium text-slate-500 relative z-10">Active Now</p>
                </div>

                <div class="stat-card glass-panel rounded-2xl p-5">
                    <div class="flex justify-between items-start mb-4">
                        <div class="p-2.5 rounded-lg bg-orange-500/10 text-orange-400">
                            <i class="ph-fill ph-clock text-xl"></i>
                        </div>
                        <span class="text-[10px] font-bold px-2 py-0.5 rounded bg-white/5 text-slate-400">System</span>
                    </div>
                    <h3 class="text-3xl font-bold text-white mb-1">
                        <%= Math.floor(uptime / 60) %><span class="text-lg text-slate-500 font-normal">m</span>
                    </h3>
                    <p class="text-sm font-medium text-slate-500">Bot Uptime</p>
                </div>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

                <div class="xl:col-span-2 glass-panel rounded-2xl p-6">
                    <div class="flex items-center justify-between mb-6">
                        <div>
                            <h3 class="text-white font-semibold">User Growth</h3>
                            <p class="text-xs text-slate-500">New interactions over last 7 days</p>
                        </div>
                        <button
                            class="text-xs font-medium text-blue-400 hover:text-blue-300 transition-colors bg-blue-500/10 px-3 py-1.5 rounded-lg border border-blue-500/20">
                            View Report
                        </button>
                    </div>
                    <div class="relative h-[300px] w-full">
                        <canvas id="growthChart"></canvas>
                    </div>
                </div>

                <div class="glass-panel rounded-2xl p-0 flex flex-col h-[400px] xl:h-auto">
                    <div class="p-4 border-b border-white/5 bg-white/[0.02] flex items-center justify-between">
                        <h3 class="text-white font-semibold text-sm flex items-center gap-2">
                            <i class="ph-bold ph-terminal-window text-slate-400"></i>
                            Live Traffic
                        </h3>
                        <span class="flex h-2 w-2 relative">
                            <span
                                class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
                        </span>
                    </div>

                    <div class="flex-1 overflow-y-auto p-2 space-y-1 scrollbar-thin" id="live-feed-container">
                        <div class="text-[10px] text-slate-500 px-2 py-1 uppercase font-bold tracking-wider">Active
                            Sessions</div>
                        <div id="live-user-list" class="space-y-1">
                            <% users.forEach(user=> { %>
                                <div
                                    class="group flex items-center justify-between p-2 rounded hover:bg-white/5 transition-colors border border-transparent hover:border-white/5 cursor-default">
                                    <div class="flex items-center gap-3">
                                        <div
                                            class="w-6 h-6 rounded bg-slate-800 flex items-center justify-center text-[10px] font-bold text-slate-300 border border-white/5">
                                            <%= user.name.charAt(0) %>
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="text-xs text-slate-300 font-medium group-hover:text-white">
                                                <%= user.name %>
                                            </span>
                                            <span class="text-[10px] text-slate-600">ID: ...<%=
                                                    user.id.toString().slice(-4) %></span>
                                        </div>
                                    </div>
                                    <div class="flex items-center gap-1.5">
                                        <div class="w-1.5 h-1.5 rounded-full bg-emerald-500"></div>
                                        <span class="text-[10px] text-slate-500 font-mono">ON</span>
                                    </div>
                                </div>
                                <% }); %>
                                    <% if(users.length===0) { %>
                                        <div class="p-4 text-center text-xs text-slate-600 italic">No active sessions...
                                        </div>
                                        <% } %>
                        </div>
                    </div>
                </div>
            </div>

            <div class="glass-panel rounded-2xl overflow-hidden">
                <div class="p-6 border-b border-white/5 flex items-center justify-between">
                    <div>
                        <h3 class="text-white font-semibold">Recent Database Entries</h3>
                        <p class="text-xs text-slate-500">Latest 10 unique users stored</p>
                    </div>
                </div>
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead>
                            <tr
                                class="bg-white/[0.02] text-xs uppercase tracking-wider text-slate-500 font-semibold border-b border-white/5">
                                <th class="px-6 py-4">User</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Joined Date</th>
                                <th class="px-6 py-4">Total Downloads</th>
                                <th class="px-6 py-4 text-right">Last Seen</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-white/5 text-sm">
                            <% dbUsers.forEach(u=> { %>
                                <% // ⚡ THE FIX: Calculate percentage OUTSIDE the style attribute to satisfy linter
                                    const progressWidth=Math.min(u.downloads * 2, 100) + '%' ; %>
                                    <tr class="hover:bg-white/[0.02] transition-colors group">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-3">
                                                <div
                                                    class="w-8 h-8 rounded-full bg-gradient-to-tr from-slate-800 to-slate-700 p-[1px] ring-1 ring-white/10 group-hover:ring-blue-500/50 transition-all">
                                                    <img src="https://ui-avatars.com/api/?name=<%= u.firstName %>&background=020617&color=cbd5e1"
                                                        class="rounded-full w-full h-full" alt="">
                                                </div>
                                                <span
                                                    class="font-medium text-slate-300 group-hover:text-white transition-colors">
                                                    <%= u.firstName %>
                                                </span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span
                                                class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-400 border border-emerald-500/10">
                                                Verified
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-slate-400">
                                            <%= u.joinedAt.toLocaleDateString('en-US', { month: 'short' , day: 'numeric'
                                                , year: 'numeric' }) %>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-2">
                                                <div class="h-1.5 w-16 bg-slate-800 rounded-full overflow-hidden">
                                                   
                                                        

                                                <span class="text-xs font-mono text-slate-300">
                                                    <%= u.downloads %>
                                                </span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 text-right text-slate-500 font-mono text-xs">
                                            <%= new Date(u.lastActive).toLocaleTimeString([], {hour: '2-digit' ,
                                                minute:'2-digit'}) %>
                                        </td>
                                    </tr>
                                    <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <script>
        // --- 📊 CHART CONFIGURATION ---
        const ctx = document.getElementById('growthChart').getContext('2d');
        const labels = JSON.parse('<%- JSON.stringify(chartData.labels) %>');
        const dataValues = JSON.parse('<%- JSON.stringify(chartData.values) %>');

        // Gradient Fill
        const gradient = ctx.createLinearGradient(0, 0, 0, 300);
        gradient.addColorStop(0, 'rgba(59, 130, 246, 0.4)');
        gradient.addColorStop(1, 'rgba(59, 130, 246, 0.0)');

        new Chart(ctx, {
            type: 'line',
            data: {
                labels: labels,
                datasets: [{
                    label: 'New Users',
                    data: dataValues,
                    borderColor: '#3b82f6',
                    backgroundColor: gradient,
                    borderWidth: 3,
                    pointBackgroundColor: '#0f172a',
                    pointBorderColor: '#60a5fa',
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: 'rgba(15, 23, 42, 0.9)',
                        titleColor: '#fff',
                        bodyColor: '#94a3b8',
                        borderColor: 'rgba(255,255,255,0.1)',
                        borderWidth: 1,
                        padding: 10,
                        displayColors: false,
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        grid: { color: 'rgba(255, 255, 255, 0.05)', drawBorder: false },
                        ticks: { color: '#64748b', font: { family: 'Plus Jakarta Sans', size: 10 } }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { color: '#64748b', font: { family: 'Plus Jakarta Sans', size: 10 } }
                    }
                }
            }
        });

        // --- 📡 REAL-TIME SOCKET UPDATES ---
        const socket = io();

        socket.on('update_stats', (data) => {
            updateCounter('stat-downloads', data.stats.downloads);
            updateCounter('stat-active', data.userList.length);

            const listContainer = document.getElementById('live-user-list');

            if (data.userList.length === 0) {
                listContainer.innerHTML = '<div class="p-4 text-center text-xs text-slate-600 italic">No active sessions...</div>';
            } else {
                listContainer.innerHTML = data.userList.map(user => `
                    <div class="group flex items-center justify-between p-2 rounded hover:bg-white/5 transition-colors border border-transparent hover:border-white/5 cursor-default fade-in">
                        <div class="flex items-center gap-3">
                            <div class="w-6 h-6 rounded bg-slate-800 flex items-center justify-center text-[10px] font-bold text-slate-300 border border-white/5">
                                ${user.name.charAt(0)}
                            </div>
                            <div class="flex flex-col">
                                <span class="text-xs text-slate-300 font-medium group-hover:text-white">${user.name}</span>
                                <span class="text-[10px] text-slate-600">ID: ...${user.id.toString().slice(-4)}</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-1.5">
                            <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
                            <span class="text-[10px] text-slate-500 font-mono">ON</span>
                        </div>
                    </div>
                `).join('');
            }
        });

        function updateCounter(id, target) {
            const el = document.getElementById(id);
            el.innerText = target;
        }
    </script>
</body>

</html>